NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public IDs only, if supplied by Mindbody's official embed configuration
NEXT_PUBLIC_MINDBODY_ASSESSMENT_WIDGET_ID=
NEXT_PUBLIC_MINDBODY_GROUP_WIDGET_ID=
NEXT_PUBLIC_MINDBODY_INBODY_WIDGET_ID=
NEXT_PUBLIC_MINDBODY_SAUNA_WIDGET_ID=

# Public fallback URL
NEXT_PUBLIC_MINDBODY_BOOKING_URL=https://www.mindbodyonline.com/explore/locations/ma5fitness-llc

# Transactional email (Resend)
RESEND_API_KEY=
CONTACT_TO_EMAIL=
# From address for contact/booking notifications (verified domain in Resend).
# Falls back to AUTH_EMAIL_FROM when unset.
CONTACT_EMAIL_FROM=
# Branded From for existing-user activation emails (required with RESEND_API_KEY
# for clear "activate access" copy instead of a generic password-reset email).
# Example: MA5 Performance <access@yourdomain.com>
AUTH_EMAIL_FROM=

# Auth email template copy (Invite + Recovery): docs/AUTH_EMAIL_TEMPLATES.md

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Supabase (platform foundation)
# Invitation-only auth checklist:
# 1) Apply supabase/migrations/009_invitation_auth.sql
# 2) Authentication → Providers → Email → disable "Enable sign ups"
#    (admin inviteUserByEmail still works with the service role key)
# 3) Authentication → URL Configuration → Redirect URLs — add BOTH:
#      http://localhost:3000/auth/callback
#      http://localhost:3000/auth/accept-invite
#      http://localhost:3000/auth/reset-password
#      https://YOUR_PRODUCTION_DOMAIN/auth/callback
#      https://YOUR_PRODUCTION_DOMAIN/auth/accept-invite
#      https://YOUR_PRODUCTION_DOMAIN/auth/reset-password
#    Add Vercel preview URLs only if you need invites/resets on previews.
# 4) Site URL should match NEXT_PUBLIC_SITE_URL for the environment you send from.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose in browser bundles
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — account-level credentials only (Price IDs live in Supabase)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Web Push (PWA) — generate with: node scripts/generate-vapid-keys.mjs
# Public key is safe in the browser; private key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ma.fitness99@gmail.com
