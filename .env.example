# Supabase (platform foundation)
# Invitation-only auth: disable public signups in the Supabase dashboard
# (Authentication → Providers → Email → turn off "Enable sign ups").
# Add these Redirect URLs under Authentication → URL Configuration:
#   {NEXT_PUBLIC_SITE_URL}/auth/callback
#   {NEXT_PUBLIC_SITE_URL}/auth/accept-invite
#   {NEXT_PUBLIC_SITE_URL}/auth/reset-password
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/accept-invite
#   http://localhost:3000/auth/reset-password
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose in browser bundles
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Mindbody-replacement demo)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create in Stripe Dashboard (test mode) then paste here
